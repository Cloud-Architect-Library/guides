{
    "name": "Cloud-Architect-Library Guides",
    "dockerComposeFile": "docker-compose.yml",
    "service": "app",
    "workspaceFolder": "/workspaces/guides",
    "customizations": {
        "vscode": {
            "extensions": [
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode",
                "formulahendry.auto-rename-tag"
            ]
        }
    },
    "forwardPorts": [
        3000
    ],
    "postCreateCommand": "npm install",
    "remoteUser": "node"
}